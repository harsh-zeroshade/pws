# ── Dependencies ──────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ──────────────────────────────────────
/.next/
/out/
/build

# ── Environment variables (NEVER commit these) ────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ── Uploads (user-uploaded files, not in version control) ─────
/public/uploads/

# ── OS / Editor ───────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
*.pem
.vscode/
.idea/

# ── Debug logs ────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Misc ──────────────────────────────────────────────────────
.vercel
*.tsbuildinfo
next-env.d.ts
/coverage
